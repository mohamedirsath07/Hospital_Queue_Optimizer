{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/health", "dest": "/api/health.py" },
    { "src": "/analyze", "dest": "/api/analyze.py" },
    { "src": "/nearby-hospitals", "dest": "/api/hospitals.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
